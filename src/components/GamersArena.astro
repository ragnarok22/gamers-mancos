---
type Platform = "nintendo" | "ps5" | "ps4" | "pc";

interface Gamer {
  id: string;
  name: string;
  gamerTag: string;
  photo: string;
  fullPhoto?: string;
  bio: string;
  platforms: Platform[];
  socials: {
    twitch?: string;
    youtube?: string;
    instagram?: string;
    twitter?: string;
  };
}

const gamers: Gamer[] = [
  {
    id: "carlos",
    name: "Carlos Lugones",
    gamerTag: "CarlosLugones",
    photo: "/gamers/carlos.webp",
    fullPhoto: "/gamers/carlos-full.webp",
    bio: "Streamer y gamer de corazón. Siempre buscando la jugada perfecta y el clip más épico.",
    platforms: ["ps5"],
    socials: {
      twitch: "https://twitch.tv/carloslugones",
      instagram: "https://instagram.com/carloslugones",
      twitter: "https://x.com/MrCarlosLugones",
    },
  },
  {
    id: "heber",
    name: "Heber",
    gamerTag: "Yudai",
    photo: "/gamers/heber.webp",
    fullPhoto: "/gamers/heber-full.webp",
    bio: "Competitivo nato. Si hay ranked, ahí estoy. Los mancos también ganamos.",
    platforms: ["nintendo", "pc"],
    socials: {
      twitch: "https://www.twitch.tv/yudaih",
      youtube: "https://youtube.com/@heber",
      twitter: "https://x.com/creativeyudai",
    },
  },
  {
    id: "reinier",
    name: "Reinier",
    gamerTag: "Ragnarok",
    photo: "/gamers/reinier.webp",
    fullPhoto: "/gamers/reinier-full.webp",
    bio: "El más manco del grupo, pero con más actitud que nadie. Content creator y amante del gaming.",
    platforms: ["ps5"],
    socials: {
      twitch: "https://twitch.tv/ragnarokreinier",
      instagram: "https://instagram.com/ragnarokreinier",
      youtube: "https://www.youtube.com/@ragnarokreinier",
    },
  },
];
---

<div id="arena" class="bg-midnight relative h-screen w-screen overflow-hidden">
  <!-- Background -->
  <img
    src="/background.png"
    alt=""
    class="absolute inset-0 h-full w-full object-cover opacity-40"
    fetchpriority="high"
  />

  <!-- Glow overlays -->
  <div class="pointer-events-none absolute inset-0" id="glow-overlay"></div>

  <!-- Center content area -->
  <div
    class="relative z-10 flex h-full flex-col items-center justify-center px-4"
  >
    <!-- Logo (default state) -->
    <div id="logo-container" class="flex flex-col items-center gap-6">
      <img
        src="/logo.png"
        alt="Gamers Mancos"
        class="max-h-[40vh] w-auto max-w-[80vw] object-contain drop-shadow-[0_0_40px_rgba(255,61,141,0.5)]"
      />
      <p
        class="font-orbitron text-text-muted text-lg tracking-[0.3em] uppercase"
      >
        Los mancos más pro
      </p>
    </div>

    <!-- Gamer spotlight (hidden by default) -->
    <div
      id="gamer-spotlight"
      class="relative flex flex-col items-center justify-end"
      role="region"
      aria-label="Perfil del gamer"
      style="display: none;"
    >
      <!-- Large image -->
      <div class="relative">
        <div
          id="spotlight-glow"
          class="absolute -inset-4 rounded-full opacity-60 blur-2xl"
          style="background: radial-gradient(circle, rgba(255,61,141,0.4), rgba(39,229,255,0.2), transparent 70%);"
        >
        </div>
        <img
          id="spotlight-img"
          src=""
          alt="Foto del gamer"
          class="spotlight-fade relative h-[60vh] w-auto object-contain md:h-[75vh]"
        />
      </div>

      <!-- Gamer tag overlapping image -->
      <h2
        id="gamer-tag"
        class="gamer-tag-shine font-orbitron pointer-events-none absolute bottom-24 z-10 text-6xl font-black tracking-wider text-transparent md:bottom-32 md:text-8xl"
        style="background: linear-gradient(90deg, #FF3D8D, #7C3AED, #27E5FF); -webkit-background-clip: text; background-clip: text;"
      >
      </h2>

      <!-- Gamer info below -->
      <div
        id="gamer-info"
        class="absolute bottom-2 z-10 flex flex-col items-center gap-2 text-center md:bottom-6"
        aria-live="polite"
      >
        <p
          id="gamer-bio"
          class="text-text-muted/80 max-w-md text-sm leading-relaxed"
        >
        </p>

        <!-- Platform icons -->
        <div id="gamer-platforms" class="flex gap-3"></div>

        <!-- Social links -->
        <div id="gamer-socials" class="flex gap-4"></div>
      </div>
    </div>
  </div>

  <!-- Bottom gamers bar -->
  <div
    id="gamers-bar"
    class="absolute right-0 bottom-0 left-0 z-20 flex items-end justify-center gap-2 px-4 pb-[max(1.5rem,env(safe-area-inset-bottom))] md:gap-4"
    role="group"
    aria-label="Seleccionar gamer"
  >
    {
      gamers.map((gamer) => (
        <button
          class="gamer-thumb group relative cursor-pointer border-0 bg-transparent p-0 outline-none"
          data-gamer-id={gamer.id}
          data-gamer-tag={gamer.gamerTag}
          data-gamer-name={gamer.name}
          data-gamer-photo={gamer.photo}
          data-gamer-full-photo={gamer.fullPhoto || gamer.photo}
          data-gamer-bio={gamer.bio}
          data-gamer-platforms={JSON.stringify(gamer.platforms)}
          data-gamer-socials={JSON.stringify(gamer.socials)}
          aria-label={`Ver perfil de ${gamer.gamerTag}`}
        >
          <div class="thumb-frame relative">
            <div class="relative flex items-center justify-center overflow-hidden">
              <img
                src={gamer.photo}
                alt={gamer.gamerTag}
                class="thumb-img h-20 w-20 object-contain transition-all duration-300 group-hover:brightness-110 md:h-32 md:w-28"
                loading="lazy"
              />
              <div class="thumb-shine pointer-events-none absolute inset-0" />
            </div>
          </div>
          <span class="font-orbitron text-text-muted/70 group-hover:text-electric-cyan mt-2 block text-center text-[10px] tracking-wider uppercase transition-colors duration-300 md:text-xs">
            {gamer.gamerTag}
          </span>
        </button>
      ))
    }
  </div>

  <!-- Floating corner selector (positioned relative to #arena) -->
  <div
    id="thumb-selector"
    class="pointer-events-none absolute"
    style="display: none;"
  >
    <span class="corner corner-tl"></span>
    <span class="corner corner-tr"></span>
    <span class="corner corner-bl"></span>
    <span class="corner corner-br"></span>
  </div>
</div>

<script>
  import gsap from "gsap";

  const logoContainer = document.getElementById("logo-container")!;
  const spotlight = document.getElementById("gamer-spotlight")!;
  const spotlightImg = document.getElementById(
    "spotlight-img",
  ) as HTMLImageElement;
  const gamerTag = document.getElementById("gamer-tag")!;
  const gamerSocials = document.getElementById("gamer-socials")!;
  const gamerPlatforms = document.getElementById("gamer-platforms")!;
  const gamerInfo = document.getElementById("gamer-info")!;
  const thumbs = document.querySelectorAll<HTMLButtonElement>(".gamer-thumb");
  const thumbSelector = document.getElementById("thumb-selector")!;

  let currentGamerId: string | null = null;
  let currentTimeline: gsap.core.Timeline | null = null;
  let logoPulse: gsap.core.Tween | null = null;

  // Reduced motion preference
  const prefersReducedMotion = window.matchMedia(
    "(prefers-reduced-motion: reduce)",
  ).matches;

  if (prefersReducedMotion) {
    gsap.globalTimeline.timeScale(1000);
  }

  // Logo idle pulse animation
  function startLogoPulse() {
    const logoImg = logoContainer.querySelector("img");
    if (!logoImg) return;
    logoPulse = gsap.to(logoImg, {
      scale: 1.02,
      filter: "drop-shadow(0 0 50px rgba(255,61,141,0.6))",
      duration: 2,
      ease: "sine.inOut",
      yoyo: true,
      repeat: -1,
    });
  }

  function stopLogoPulse() {
    if (logoPulse) {
      logoPulse.kill();
      logoPulse = null;
      const logoImg = logoContainer.querySelector("img");
      if (logoImg) {
        gsap.set(logoImg, { scale: 1, clearProps: "filter" });
      }
    }
  }

  // Move the floating corner selector to a thumb
  function moveSelector(button: HTMLButtonElement, instant = false) {
    const frame = button.querySelector(".thumb-frame") as HTMLElement;
    if (!frame) return;

    const arenaRect = document.getElementById("arena")!.getBoundingClientRect();
    const frameRect = frame.getBoundingClientRect();

    const x = frameRect.left - arenaRect.left;
    const y = frameRect.top - arenaRect.top;
    const w = frameRect.width;
    const h = frameRect.height;

    const pad = 6;
    const targetLeft = x - pad;
    const targetTop = y - pad;
    const targetWidth = w + pad * 2;
    const targetHeight = h + pad * 2;

    if (thumbSelector.style.display === "none" || instant) {
      thumbSelector.style.display = "block";
      gsap.set(thumbSelector, {
        left: targetLeft,
        top: targetTop,
        width: targetWidth,
        height: targetHeight,
        opacity: 1,
      });
    } else {
      gsap.to(thumbSelector, {
        left: targetLeft,
        top: targetTop,
        width: targetWidth,
        height: targetHeight,
        duration: 0.25,
        ease: "power2.out",
      });
    }
  }

  function hideSelector() {
    gsap.to(thumbSelector, {
      opacity: 0,
      duration: 0.2,
      onComplete: () => {
        thumbSelector.style.display = "none";
      },
    });
  }

  // Start the pulse on load (skip if user prefers reduced motion)
  if (!prefersReducedMotion) {
    startLogoPulse();
  }

  function showGamer(button: HTMLButtonElement) {
    const gamerId = button.dataset.gamerId!;
    if (gamerId === currentGamerId) return;

    // Kill any in-progress spotlight animation
    if (currentTimeline) {
      currentTimeline.kill();
      currentTimeline = null;
    }
    const wasShowingGamer = currentGamerId !== null;
    currentGamerId = gamerId;

    const photo = button.dataset.gamerFullPhoto || button.dataset.gamerPhoto!;
    const tag = button.dataset.gamerTag!;
    const name = button.dataset.gamerName!;

    // Update active thumb styling and retrigger shine
    thumbs.forEach((t) => t.classList.remove("active-thumb"));
    void button.offsetWidth;
    button.classList.add("active-thumb");

    // Move floating selector to this thumb
    moveSelector(button, !wasShowingGamer);

    const tl = gsap.timeline({
      onComplete: () => {
        currentTimeline = null;
      },
    });
    currentTimeline = tl;

    // If logo is visible, fade it out first and kill pulse
    if (logoContainer.style.display !== "none") {
      stopLogoPulse();
      tl.to(logoContainer, {
        opacity: 0,
        y: -30,
        duration: 0.3,
        ease: "power2.in",
        onComplete: () => {
          logoContainer.style.display = "none";
        },
      });
    }

    // If switching gamer-to-gamer, immediately hide old content so new one can animate in
    if (wasShowingGamer) {
      gsap.set(spotlightImg, { opacity: 0 });
      gsap.set(gamerInfo, { opacity: 0 });
    }

    // Ensure logo is hidden if it was mid-fade
    if (wasShowingGamer && logoContainer.style.display !== "none") {
      logoContainer.style.display = "none";
      gsap.set(logoContainer, { opacity: 0 });
    }

    // Set new data
    tl.call(() => {
      spotlightImg.src = photo;
      spotlightImg.alt = `Foto de ${name}`;
      gamerTag.textContent = tag;

      gamerPlatforms.innerHTML = "";
      gamerSocials.innerHTML = "";

      spotlight.style.display = "flex";

      if (!wasShowingGamer) {
        gsap.set(spotlight, { opacity: 0 });
      }
      gsap.set(spotlightImg, {
        y: wasShowingGamer ? -30 : 40,
        opacity: 0,
        scale: 0.95,
      });
      gsap.set(gamerTag, { y: 20, opacity: 0 });
      gsap.set(gamerInfo, { y: 20, opacity: 0 });

      // Set platform badges and social links to hidden for stagger
      const platformBadges = gamerPlatforms.querySelectorAll(".platform-badge");
      if (platformBadges.length)
        gsap.set(platformBadges, { opacity: 0, y: 10 });
      const socialLinks = gamerSocials.querySelectorAll(".social-link");
      if (socialLinks.length) gsap.set(socialLinks, { opacity: 0, y: 10 });
    });

    // Animate spotlight in
    if (!wasShowingGamer) {
      tl.to(spotlight, {
        opacity: 1,
        duration: 0.1,
      });
    }

    tl.to(spotlightImg, {
      y: 0,
      opacity: 1,
      scale: 1,
      duration: wasShowingGamer ? 0.45 : 0.6,
      ease: "power3.out",
    });

    // Gamer tag overlaps image
    tl.to(
      gamerTag,
      {
        y: 0,
        opacity: 1,
        duration: 0.5,
        ease: "power2.out",
      },
      "-=0.3",
    );

    // Then info fades in
    tl.to(
      gamerInfo,
      {
        y: 0,
        opacity: 1,
        duration: 0.5,
        ease: "power2.out",
      },
      "-=0.2",
    );

    // Stagger platform badges
    tl.call(
      () => {
        const platformBadges =
          gamerPlatforms.querySelectorAll(".platform-badge");
        if (platformBadges.length) {
          gsap.to(platformBadges, {
            opacity: 1,
            y: 0,
            duration: 0.3,
            stagger: 0.08,
            ease: "power2.out",
          });
        }
      },
      [],
      "-=0.3",
    );

    // Stagger social link icons
    tl.call(
      () => {
        const socialLinks = gamerSocials.querySelectorAll(".social-link");
        if (socialLinks.length) {
          gsap.to(socialLinks, {
            opacity: 1,
            y: 0,
            duration: 0.3,
            stagger: 0.08,
            ease: "power2.out",
          });
        }
      },
      [],
      "-=0.2",
    );

    // Trigger shine animation on gamer tag
    tl.call(
      () => {
        gamerTag.classList.remove("shine-active");
        void gamerTag.offsetWidth; // force reflow to restart animation
        gamerTag.classList.add("shine-active");
      },
      [],
      "-=0.2",
    );
  }

  function resetToLogo() {
    if (!currentGamerId) return;
    if (currentTimeline) {
      currentTimeline.kill();
      currentTimeline = null;
    }
    currentGamerId = null;

    thumbs.forEach((t) => t.classList.remove("active-thumb"));
    hideSelector();

    const tl = gsap.timeline();

    tl.to(spotlight, {
      opacity: 0,
      y: 20,
      duration: 0.3,
      ease: "power2.in",
      onComplete: () => {
        spotlight.style.display = "none";
        gsap.set(spotlight, { y: 0 });
      },
    });

    tl.call(() => {
      logoContainer.style.display = "flex";
      gsap.set(logoContainer, { opacity: 0, y: 30 });
    });

    tl.to(logoContainer, {
      opacity: 1,
      y: 0,
      duration: 0.5,
      ease: "power3.out",
      onComplete: () => {
        if (!prefersReducedMotion) {
          startLogoPulse();
        }
      },
    });
  }

  // Helper: navigate to next/prev gamer
  function navigateGamer(direction: "next" | "prev") {
    const thumbArray = Array.from(thumbs);
    const currentIndex = thumbArray.findIndex(
      (t) => t.dataset.gamerId === currentGamerId,
    );
    let targetIndex: number;
    if (direction === "next") {
      targetIndex = currentIndex < thumbArray.length - 1 ? currentIndex + 1 : 0;
    } else {
      targetIndex = currentIndex > 0 ? currentIndex - 1 : thumbArray.length - 1;
    }
    thumbArray[targetIndex].focus();
    showGamer(thumbArray[targetIndex]);
  }

  // Event listeners
  thumbs.forEach((thumb) => {
    thumb.addEventListener("mouseenter", () => showGamer(thumb));
    thumb.addEventListener("focus", () => showGamer(thumb));
    thumb.addEventListener("click", (e) => {
      e.stopPropagation();
      showGamer(thumb);
    });
  });

  // Click on background area resets to logo
  document.getElementById("arena")!.addEventListener("click", (e) => {
    const target = e.target as HTMLElement;
    if (
      !target.closest(".gamer-thumb") &&
      !target.closest("#gamer-spotlight")
    ) {
      resetToLogo();
    }
  });

  // Swipe gestures
  let touchStartX: number | null = null;
  const arena = document.getElementById("arena")!;

  arena.addEventListener(
    "touchstart",
    (e) => {
      touchStartX = e.changedTouches[0].clientX;
    },
    { passive: true },
  );

  arena.addEventListener(
    "touchend",
    (e) => {
      if (touchStartX === null) return;
      const deltaX = e.changedTouches[0].clientX - touchStartX;
      touchStartX = null;
      if (Math.abs(deltaX) < 50) return;
      if (deltaX < 0) {
        navigateGamer("next");
      } else {
        navigateGamer("prev");
      }
    },
    { passive: true },
  );

  // Keyboard navigation
  document.addEventListener("keydown", (e) => {
    if (e.key === "ArrowRight" || e.key === "ArrowDown") {
      e.preventDefault();
      navigateGamer("next");
    } else if (e.key === "ArrowLeft" || e.key === "ArrowUp") {
      e.preventDefault();
      navigateGamer("prev");
    } else if (e.key === "Escape") {
      resetToLogo();
    }
  });
</script>

<style>
  .thumb-frame {
    width: 128px;
    height: 128px;
  }

  /* Floating corner bracket selector */
  #thumb-selector {
    z-index: 30;
  }

  .corner {
    --size: 16px;
    --thickness: 4px;
    position: absolute;
    width: var(--size);
    height: var(--size);
    filter: drop-shadow(0 0 4px currentColor);
    animation: corner-pulse 1.5s ease-in-out infinite;
  }

  .corner-tl {
    top: 0;
    left: 0;
    border-top: var(--thickness) solid var(--color-neon-pink);
    border-left: var(--thickness) solid var(--color-neon-pink);
  }

  .corner-tr {
    top: 0;
    right: 0;
    border-top: var(--thickness) solid var(--color-neon-pink);
    border-right: var(--thickness) solid var(--color-neon-pink);
  }

  .corner-bl {
    bottom: 0;
    left: 0;
    border-bottom: var(--thickness) solid var(--color-electric-cyan);
    border-left: var(--thickness) solid var(--color-electric-cyan);
  }

  .corner-br {
    bottom: 0;
    right: 0;
    border-bottom: var(--thickness) solid var(--color-electric-cyan);
    border-right: var(--thickness) solid var(--color-electric-cyan);
  }

  @keyframes corner-pulse {
    0%,
    100% {
      filter: drop-shadow(0 0 4px currentColor);
    }
    50% {
      filter: drop-shadow(0 0 8px currentColor);
    }
  }

  /* Thumb shine sweep */
  .thumb-shine::after {
    content: "";
    position: absolute;
    top: 0;
    left: -100%;
    width: 60%;
    height: 100%;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255, 255, 255, 0.35),
      transparent
    );
    transform: skewX(-20deg);
  }

  .active-thumb .thumb-shine::after {
    animation: thumb-shine-sweep 0.6s ease-out forwards;
  }

  @keyframes thumb-shine-sweep {
    0% {
      left: -60%;
    }
    100% {
      left: 130%;
    }
  }

  /* Active thumb styling */
  .active-thumb .thumb-img {
    filter: brightness(1.15);
  }

  .active-thumb span {
    color: var(--color-electric-cyan) !important;
  }

  #glow-overlay {
    background:
      radial-gradient(
        circle at 30% 20%,
        rgba(255, 61, 141, 0.15),
        transparent 55%
      ),
      radial-gradient(
        circle at 80% 30%,
        rgba(39, 229, 255, 0.1),
        transparent 55%
      ),
      radial-gradient(
        circle at 50% 80%,
        rgba(124, 58, 237, 0.12),
        transparent 50%
      );
  }

  .font-orbitron {
    font-family: var(--font-orbitron);
  }

  .gamer-tag-shine {
    position: relative;
    overflow: hidden;
  }

  .gamer-tag-shine::after {
    content: "";
    position: absolute;
    top: 0;
    left: -100%;
    width: 60%;
    height: 100%;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255, 255, 255, 0.4),
      transparent
    );
    transform: skewX(-20deg);
    opacity: 0;
    pointer-events: none;
  }

  .gamer-tag-shine.shine-active::after {
    animation: shine-sweep 0.8s ease-out forwards;
  }

  @keyframes shine-sweep {
    0% {
      left: -60%;
      opacity: 0;
    }
    20% {
      opacity: 1;
    }
    100% {
      left: 120%;
      opacity: 0;
    }
  }

  /* Fade the bottom of the spotlight image to transparent */
  .spotlight-fade {
    mask-image: linear-gradient(to bottom, black 60%, transparent 100%);
    -webkit-mask-image: linear-gradient(to bottom, black 60%, transparent 100%);
  }
</style>
